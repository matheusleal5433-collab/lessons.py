"""
Fatiamento de Strings
 012345678
 Olá mundo 
-987654321
Fatiamento [i:f:p] [::]
Obs.: a funçao len retorna a qtd
de caracteres da str
"""
variavel = 'Olá mundo'
print(variavel[4:7])
print(variavel[:])
print(variavel[3:8])
print(variavel[-7:-2])
print(len(variavel[3]))
print(variavel[-1:-10:-1])



